# Runtime
NODE_ENV=development
PORT=4000

# Public URL used when the backend returns downloadable file links.
# Production example: https://api.editio.example
# Local device example: http://YOUR_COMPUTER_LAN_IP:4000
PUBLIC_BASE_URL=http://your-computer-lan-ip:4000

# Comma-separated browser origins. Native mobile requests normally have no Origin header.
# Production example: https://editio.example
# Local Expo web example: http://localhost:8081,http://localhost:8082
ALLOWED_ORIGINS=

# Storage and limits
# In Docker production this should normally be /app/data/downloads.
DOWNLOAD_DIR=downloads
# Account database. In Docker production mount /app/data as a persistent volume.
DATABASE_PATH=data/editio.sqlite
MAX_INPUT_MB=100
MAX_FILES_PER_REQUEST=10
MAX_CONCURRENT_JOBS=2
MAX_PENDING_JOBS=10
JOB_TTL_MINUTES=30
TRUST_PROXY_HOPS=0

# Accounts and legal acceptance
AUTH_SESSION_DAYS=30
MIN_ACCOUNT_AGE=13
TERMS_VERSION=2026-07-15
PRIVACY_VERSION=2026-07-16

# Support form email delivery
# Gmail: create an App Password for the SMTP_USER account; never commit it.
SUPPORT_TO_EMAIL=editioapp@gmail.com
SUPPORT_MAX_ATTACHMENT_MB=10
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=editioapp@gmail.com
SMTP_PASS=
SMTP_FROM=Editio Support <editioapp@gmail.com>

# Apple auto-renewable subscriptions. Keep disabled until App Store Connect,
# Apple credentials, notifications, and the mobile flag are ready together.
MONETIZATION_ENABLED=false
# Set to the first iOS build that contains the billing authorization flow before enabling monetization.
MONETIZATION_MIN_IOS_BUILD=
FREE_CONVERSION_LIMIT=3
CONVERSION_AUTHORIZATION_TTL_MINUTES=15
APPLE_BUNDLE_ID=com.cantecim.editio
APPLE_APP_ID=6790405876
APPLE_MONTHLY_PRODUCT_ID=com.cantecim.editio.pro.monthly
APPLE_YEARLY_PRODUCT_ID=com.cantecim.editio.pro.yearly
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY_PATH=
# Comma-separated: Xcode,Sandbox,Production. Do not include Production during
# local verification unless production-signed transactions are expected.
APPLE_IAP_ENVIRONMENT=Xcode,Sandbox
APPLE_ROOT_CA_DIRECTORY=
APPLE_NOTIFICATION_PRODUCTION_URL=https://api.editioapp.com/billing/apple/notifications
APPLE_NOTIFICATION_SANDBOX_URL=https://api.editioapp.com/billing/apple/notifications

# Optional binary overrides. Leave empty to use bundled ffmpeg-static/ffprobe-static.
FFMPEG_PATH=
FFPROBE_PATH=
