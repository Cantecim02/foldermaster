# Runtime
NODE_ENV=development
PORT=4000

# Public URL used when the backend returns downloadable file links.
# Production example: https://api.editio.example
# Local device example: http://YOUR_COMPUTER_LAN_IP:4000
PUBLIC_BASE_URL=http://your-computer-lan-ip:4000

# Comma-separated browser origins. Native mobile requests normally have no Origin header.
# Production example: https://editio.example
# Local Expo web example: http://localhost:8081,http://localhost:8082
ALLOWED_ORIGINS=

# Storage and limits
# In Docker production this should normally be /app/data/downloads.
DOWNLOAD_DIR=downloads
# Account database. In Docker production mount /app/data as a persistent volume.
DATABASE_PATH=data/editio.sqlite
MAX_INPUT_MB=100
MAX_FILES_PER_REQUEST=10
MAX_CONCURRENT_JOBS=2
MAX_PENDING_JOBS=10
JOB_TTL_MINUTES=30
TRUST_PROXY_HOPS=0

# Accounts and legal acceptance
AUTH_SESSION_DAYS=30
MIN_ACCOUNT_AGE=13
TERMS_VERSION=2026-07-15
PRIVACY_VERSION=2026-07-15

# Optional binary overrides. Leave empty to use bundled ffmpeg-static/ffprobe-static.
FFMPEG_PATH=
FFPROBE_PATH=
