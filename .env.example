# Production API URL for the existing Editio backend.
# App Store builds must use a deployed HTTPS backend URL, not localhost or a LAN IP.
EXPO_PUBLIC_MEDIA_API_URL=https://api.example.com

# Optional dev helper. If EXPO_PUBLIC_MEDIA_API_URL points at localhost in a
# native development build, the app rewrites the host to the current Metro host
# and keeps this backend port.
EXPO_PUBLIC_MEDIA_API_PORT=4000

# Keep false for App Store builds. Set true only in internal developer builds
# when you need the hidden diagnostics screen.
EXPO_PUBLIC_INTERNAL_DIAGNOSTICS=false
